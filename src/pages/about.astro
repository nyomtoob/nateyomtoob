---
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About',
};
---

<Layout metadata={metadata}>
  <Hero>
    <Fragment slot="title">Hey, I'm Nate</Fragment>

    <Fragment slot="subtitle">
      Integration Technician by day, Bears fan by heartbreak and hype, and someone who built a whole website to avoid
      the brainrot. Big shoutout to my dog Ernie and my cat Ronny. This is where I write about the stuff I actually
      think about.
    </Fragment>
  </Hero>

  <Steps2
    title="What I Do"
    items={[
      {
        title: 'How I got here',
        description: "I have a CS degree, but these days I'm in the hardware world as an Integration Technician.",
      },
      {
        title: 'What I work on',
        description: 'I break down, build, configure, and provide solutions for Dell PowerEdge server systems.',
      },
      {
        title: 'Day to day',
        description:
          "I'm hands on with enterprise hardware, making sure systems are properly spec'd, set up, and running the way they should.",
      },
    ]}
  />

  <Features2
    title="What I'm Into"
    items={[
      {
        title: 'Football',
        icon: 'tabler:ball-american-football',
        description:
          'Bears fan for life. After years of suffering the rebuild is finally paying off and the hype is real. Big ten football fan too.',
      },
      {
        title: 'Basketball',
        icon: 'tabler:ball-basketball',
        description:
          'Pistons fan and loving every second of it right now. Currently the 1 seed in the playoffs and it has been a long time coming.',
      },
      {
        title: 'NASCAR',
        icon: 'tabler:steering-wheel',
        description: 'Love the sport, the strategy, the chaos. Always watching on race day.',
      },
      {
        title: 'Gaming',
        icon: 'tabler:device-gamepad-2',
        description:
          'Mostly Deadlock and Valorant. I follow the esports scenes more than I grind ranked but I do both.',
      },
      {
        title: 'Film and TV',
        icon: 'tabler:movie',
        description:
          'Goodfellas is the best movie ever made, not up for debate. Currently watching Snowfall. Always down to talk about a good show or film.',
      },
    ]}
  />

  <Features2
    title="Currently"
    subtitle="Snapshot of what I'm into right now. I'll keep this updated."
    columns={3}
    items={[
      {
        title: 'Watching',
        description: 'Snowfall',
      },
      {
        title: 'Playing',
        description: 'Deadlock and Valorant',
      },
      {
        title: 'Following',
        description: 'Pistons playoff run',
      },
    ]}
  />

  <Features2
    title="Find Me"
    columns={1}
    items={[
      {
        title: 'GitHub',
        icon: 'tabler:brand-github',
        description: 'Where my code lives.',
        callToAction: {
          text: 'github.com/nyomtoob',
          href: 'https://github.com/nyomtoob',
          variant: 'link',
        },
      },
    ]}
  />
</Layout>
