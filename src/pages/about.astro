---
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About',
};
---

<Layout metadata={metadata}>
  <Hero>
    <Fragment slot="title">Hey, I'm Nate</Fragment>

    <Fragment slot="subtitle">
      Computer guy by day, cursed to be a Bears fan, and decided to build this website to learn a new skill I haven't
      tried before. Big shoutout to my dog Ernie and my cat Ronny. My plan is to use this as a place to share my thoughts and work.
    </Fragment>
  </Hero>

  <Steps2
    title="What I Do (8-5)"
    items={[
      {
        title: 'How I got here',
        description: "Got a degree in computer science from UM-Dearborn. Transitioned more to hardware out of college so these days I'm in the real world as an Integration Technician.",
      },
      {
        title: 'What I work on',
        description: 'I break down, build, configure, and provide solutions for Dell PowerEdge server systems.',
      },
      {
        title: 'Day to day',
        description:
          "I'm hands on with enterprise hardware, making sure systems are properly spec'd, set up, and running the way they should.",
      },
    ]}
  />

  <Features2
    title="What I'm Into"
    items={[
      {
        title: 'Football',
        icon: 'tabler:ball-american-football',
        description:
          'Bears fan my entire life. After years of suffering the rebuild is finally paying off and the hype is real.',
      },
      {
        title: 'Basketball',
        icon: 'tabler:ball-basketball',
        description:
          'Pistons fan and loving every second of it right now. Currently the 1 seed in the playoffs and it has been a long time coming. Thank you Cade.',
      },
      {
        title: 'NASCAR',
        icon: 'tabler:steering-wheel',
        description:
          "Shoutout Papa John for putting me in 3 gear out the gate. Avoided it for a long time because it wasn't cool. Got back into it in 2025",
      },
      {
        title: 'Gaming',
        icon: 'tabler:device-gamepad-2',
        description:
          'Mostly Deadlock and Valorant. Valorant is in a tough spot right now but still fun to watch, Deadlock has me hooked with an awesome gamepaly loop.',
      },
      {
        title: 'Film and TV',
        icon: 'tabler:movie',
        description:
          'Got into film when I was 17 and have only grown to love the art form more. All-time favorite is Goodfellas and for TV is has to be Snowfall.',
      },
    ]}
  />

  <Features2
    title="Currently"
    subtitle="Snapshot of what I'm into right now. I'll keep this updated."
    columns={3}
    items={[
      {
        title: 'Watching',
        description: 'Invincible',
      },
      {
        title: 'Playing',
        description: 'Deadlock',
      },
      {
        title: 'Following',
        description: 'Pistons playoff run',
      },
    ]}
  />

  <Features2
    title="Find Me"
    columns={1}
    items={[
      {
        title: 'GitHub',
        icon: 'tabler:brand-github',
        description: 'Where my code lives.',
        callToAction: {
          text: 'github.com/nyomtoob',
          href: 'https://github.com/nyomtoob',
          variant: 'link',
        },
      },
    ]}
  />
</Layout>
